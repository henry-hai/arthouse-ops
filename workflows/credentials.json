[
  {
    "id": "arthouseWpBasicAuth",
    "name": "ArtHouse WordPress Basic Auth",
    "type": "httpBasicAuth",
    "data": {
      "user": "={{ $env.WP_USERNAME }}",
      "password": "={{ $env.WP_APP_PASSWORD }}"
    }
  },
  {
    "id": "arthouseAnthropic",
    "name": "Anthropic API",
    "type": "httpHeaderAuth",
    "data": {
      "name": "x-api-key",
      "value": "={{ $env.ANTHROPIC_API_KEY }}"
    }
  },
  {
    "id": "arthouseGoogleSheets",
    "name": "ArtHouse Google Sheets",
    "type": "googleSheetsOAuth2Api",
    "data": {
      "clientId": "",
      "clientSecret": ""
    }
  },
  {
    "id": "arthouseGmail",
    "name": "ArtHouse Gmail",
    "type": "gmailOAuth2",
    "data": {
      "clientId": "",
      "clientSecret": ""
    }
  }
]
