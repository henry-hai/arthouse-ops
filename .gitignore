# Secrets: the real environment file is never committed. Only .env.example is tracked.
.env
.env.*
!.env.example

# n8n local data folder if the volume is ever bind-mounted for debugging
n8n-data/
.n8n/

# Generated outputs
outputs/

# Node
node_modules/

# macOS
.DS_Store

# Personal resume-prep context file, local only
arthouse-ops-context.txt

# Local setup guides, not part of the published repo
docs/

# Downloaded Google OAuth client secret files, keep local only
client_secret*.json
*.apps.googleusercontent.com.json

# Local secrets backup folder, never commit
secrets/

# Real form-data exports may contain student PII, never commit them
inputs/*.csv
inputs/*.txt
inputs/*.xls
inputs/*.xlsx
data/*.csv
data/*.txt

# Built plugin zip is a build artifact, keep only the .php source
wordpress-plugin/*.zip
