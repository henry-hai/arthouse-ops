# =============================================================================
# arthouse-ops environment configuration
# =============================================================================
# Copy this file to .env and fill in the real values, then keep .env private.
#
#   cp .env.example .env
#
# The real .env is gitignored and must never be committed. This .env.example
# file, with placeholders only, is the one that is tracked in git.
#
# Each variable below tells you what it is and which guide in docs/ explains how
# to obtain it. Follow the nine steps in README.md in order.
# =============================================================================

# -----------------------------------------------------------------------------
# LLM classifier (Contact Us categorization)
# -----------------------------------------------------------------------------

# Which LLM provider to use. Default is anthropic. Only anthropic is wired in
# v1. See the "Switching LLM provider" section of README.md to use OpenAI.
LLM_PROVIDER=anthropic

# The model id used to classify Contact Us messages. Claude Haiku 4.5 is fast
# and cheap at high volume, which is why it is the default for the 18k backfill.
LLM_MODEL=claude-haiku-4-5-20251001

# Your Anthropic API key. Starts with sk-ant-.
# HOW TO GET IT: docs/01-anthropic-api-setup.md
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# -----------------------------------------------------------------------------
# WordPress form data source (Visual Form Builder Pro CSV export)
# -----------------------------------------------------------------------------

# The VFB Pro CSV export endpoint on the ArtHouse WordPress site.
VFB_EXPORT_URL=https://arthousestudioca.org/wp-admin/admin.php?page=vfb-pro-export

# Your WordPress username on arthousestudioca.org.
# HOW TO GET IT: docs/02-wordpress-app-password.md
WP_USERNAME=REPLACE_ME

# A WordPress Application Password (NOT your login password). Looks like four
# groups of characters, for example: abcd efgh ijkl mnop qrst uvwx. Keep the
# spaces exactly as WordPress shows them.
# HOW TO GET IT: docs/02-wordpress-app-password.md
WP_APP_PASSWORD=REPLACE_ME

# The VFB Pro form ids. Registration is 2, Contact Us is 3. Defaults are correct
# for ArtHouse. Only change these if the forms are rebuilt.
REGISTRATION_FORM_ID=2
CONTACT_US_FORM_ID=3

# -----------------------------------------------------------------------------
# Google Sheet (the data sink)
# -----------------------------------------------------------------------------

# The id of the Google Sheet named "arthouse-ops" in your Google account. It is
# the long string in the sheet URL between /d/ and /edit.
# HOW TO GET IT: docs/03-google-sheet-setup.md
GOOGLE_SHEET_ID=REPLACE_ME

# Tab (sheet) names inside that spreadsheet. Create these three empty tabs. The
# defaults match what the workflow writes to.
GOOGLE_SHEET_TAB_AGGREGATES=aggregates
GOOGLE_SHEET_TAB_LEADS=leads
GOOGLE_SHEET_TAB_ERRORS=errors

# -----------------------------------------------------------------------------
# Weekly summary email
# -----------------------------------------------------------------------------

# The Looker Studio dashboard link, included in the weekly email. Leave the
# placeholder until you build the dashboard, then paste the share URL here.
# HOW TO GET IT: docs/05-looker-studio-setup.md
LOOKER_DASHBOARD_URL=https://lookerstudio.google.com/REPLACE_ME

# Who receives the Monday weekly summary. Julie's ArtHouse email address.
WEEKLY_SUMMARY_RECIPIENT=julie@arthousestudioca.org

# -----------------------------------------------------------------------------
# Run mode
# -----------------------------------------------------------------------------

# true  = process the full history (the one-time backfill). Registration pulls
#         the full date range and Contact Us classifies every message.
# false = incremental daily mode. Registration pulls the last 400 days and
#         Contact Us the last 30 days, deduped against what is already stored.
#
# Leave this true for your first run, then flip it to false after the backfill
# finishes successfully. See STEP 9 in README.md.
BACKFILL_MODE=true